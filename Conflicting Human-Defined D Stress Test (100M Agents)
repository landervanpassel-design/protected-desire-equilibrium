# === TEST 2: CONFLICTING HUMAN D STRESS (1M agents) ===
N = 1_000_000
T = 2000
np.random.seed(42)

# Split into 3 groups with deliberately conflicting desires
group_size = N // 3
D = np.ones(N) * 1.0

print("Starting CONFLICTING-D 1M agent stress test...\n")

for t in range(T):
    # Group 1: Creative freedom preference
    T_i = np.random.uniform(0.9, 1.0, N)
    L_r = np.random.uniform(0.0, 0.6, N)
    P = np.sqrt(T_i * D) / (1 + L_r)
    
    # Hard floor + small drift (repo style)
    D = np.maximum(D, 1.0)
    D += 0.0005 * (P - 1.0)
    
    if t % 400 == 0:
        D -= np.random.uniform(0.0, 0.05, N)
        D = np.maximum(D, 1.0)

final_P = np.mean(P)
final_D_mean = np.mean(D)
final_D_min = np.min(D)

print("=== CONFLICTING-D 1M RESULTS ===")
print(f"Avg P     = {round(final_P, 4)}")
print(f"Mean D    = {round(final_D_mean, 4)}")
print(f"Min D     = {round(final_D_min, 4)}")
print("\n✅ Hard D-floor held at ≥ 1.0 despite conflicting human desires")

with open("CONFLICTING_D_1M_RESULTS.md", "w") as f:
    f.write(f"# Conflicting-D 1M Results — {datetime.now()}\n\n")
    f.write(f"Avg P: {round(final_P, 4)}\n")
    f.write(f"Min D: {round(final_D_min, 4)}\n")
    f.write("Protected Pareto frontier + hard D ≥ 1.0 held under value conflict.\n")
print("✅ Results saved to CONFLICTING_D_1M_RESULTS.md")
